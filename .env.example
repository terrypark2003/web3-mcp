# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Load with:  set -a; . ./.env; set +a

# --- Telegram ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=            # from @BotFather
TELEGRAM_OWNER_ID=             # your numeric Telegram user id; bot ignores all others

# --- Execution mode ---------------------------------------------------------
EXECUTION_MODE=dry-run        # dry-run (default, places nothing) | live
MAX_STAKE_USDC=1              # cap per trade; start at 1 for a functional test
SLIPPAGE=0.01                 # marketable-limit buffer over the quoted ask

# --- Proactive alerts -------------------------------------------------------
ALERTS_ENABLED=true          # push a message when new arbs appear
ALERT_INTERVAL_SEC=300       # how often to poll
ALERT_MIN_EDGE_PCT=0         # only alert on edges at/above this percent

# --- Favorites "tap to buy $1" (interactive bot only; NOT risk-free) --------
# The long-running bot (telegram_bot.py) posts near-resolution favorites with a
# "$1 매수" button. Tap -> it stages the order and shows it; a second Confirm tap
# places it. Dry-run unless EXECUTION_MODE=live (+ credentials below). The $1 cap
# and the price band (NOTIFY_FAV_*) above bound every order.
FAV_INTERVAL_SEC=900         # how often the bot posts favorites with buy buttons
FAV_BUY_USD=1                # $ per one-tap buy (keep at 1)

# --- Cross-venue / EV / signals channel -------------------------------------
SIGNAL_CHANNEL_ID=           # Telegram channel/group id to broadcast risk-free edges to
FAIR_VALUES_FILE=            # path to {market_id: P(YES)} JSON to enable live /ev

# --- Web dashboard (polymarket_arb.webapp) ----------------------------------
DASHBOARD_TOKEN=             # REQUIRED to run the dashboard; sent as X-Dashboard-Token
WEB_HOST=127.0.0.1           # localhost only; 0.0.0.0 exposes a trading UI (danger)
WEB_PORT=8000
WEB_DEMO=                    # set to 1 to serve bundled demo data (no network/keys)

# --- Scheduled Telegram notifier (polymarket_arb.notify) --------------------
# In GitHub Actions these are repo Secrets, not .env. Here for local testing.
TELEGRAM_CHAT_ID=            # your numeric chat id (falls back to TELEGRAM_OWNER_ID)
NOTIFY_DEMO=                 # 1 = send a labelled demo message (test the wiring)
NOTIFY_MODE=arb             # arb (default) | world_cup | favorites
NOTIFY_MIN_EDGE_PCT=0        # only notify on edges at/above this percent
NOTIFY_MIN_CONFIDENCE=0      # only notify on risk-free ops at/above this realism score (0-100)
NOTIFY_MAX_DAYS=1            # favorites: only markets resolving within N days (1 = within a day)
NOTIFY_INCLUDE_EV=           # 1 = also include positive-EV signals (opinion)

# --- Near-resolution favorites (NOTIFY_MODE=favorites) ----------------------
# Soon-resolving outcomes priced like favorites ("$1 -> ~$1.1 if it wins").
# NOT risk-free: the price IS the implied probability. Any market, not just sports.
NOTIFY_FAV_MIN_PRICE=0.87   # price floor; 0.87 -> ~1.15x payout ("$1 -> $1.15")
NOTIFY_FAV_MAX_PRICE=0.95   # price ceiling; 0.95 -> ~1.05x payout ("$1 -> $1.05"). Band = $1 -> $1.05~1.15
NOTIFY_FAV_MIN_SIZE=5       # min shares available at the ask (real depth)
NOTIFY_FAV_BOOK_LIMIT=120   # only price the N soonest candidates (keeps /fav fast; "더보기" pages the rest)
# Drop markets whose question contains any of these (comma-separated). Leave it
# UNSET (the default below is commented out) to keep the built-in crypto filter
# (Bitcoin/ETH "Up or Down" hourlies etc.). Set to empty to keep everything, or
# to your own list to override.
# NOTIFY_FAV_EXCLUDE=up or down,bitcoin,ethereum,solana

# --- Settlement watcher (win/lose alerts) ------------------------------------
# Proactively pings you when a held position resolves. Requires POLYMARKET_FUNDER
# (below) — without it, the watcher is silently disabled.
SETTLEMENT_CHECK_INTERVAL_SEC=300   # how often to poll positions (seconds)
SETTLEMENT_STATE_FILE=settlement_state.json   # persists across restarts so you
                                               # aren't re-notified about the same result

# --- World Cup value betting (NOTIFY_MODE=world_cup, `world-cup` command) ----
ODDS_API_KEY=               # from the-odds-api.com (free ~500 req/mo); bookmaker consensus
NOTIFY_WC_MIN_EDGE=0.05     # min per-match value edge over consensus, 0-1 ("$1 -> ~$1.05" = 0.05)

# --- Gemini analysis layer (explains/queries; never the probability source) --
GEMINI_API_KEY=             # from Google AI Studio; enables /ask in the bot
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENRICH=              # 1 = append a one-line Gemini note to alert messages

# --- Polymarket CLOB API credentials (L2) -----------------------------------
# OPTIONAL: these are auto-derived from POLYMARKET_PRIVATE_KEY at connect time,
# so you can leave them blank. Set them only to skip the derive call (generate
# with `python scripts/make_creds.py`). Not found in any Polymarket UI.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --- Signing wallet (settles on Polygon) ------------------------------------
# The private key that signs orders. NEVER commit this. Consider a dedicated
# wallet funded with only what you intend to trade.
POLYMARKET_PRIVATE_KEY=
# Polymarket-funded accounts trade through a PROXY wallet. Set both of these to
# the proxy, or orders sign from an unfunded EOA and fail:
POLYMARKET_FUNDER=            # your Polymarket deposit/proxy address
POLYMARKET_SIGNATURE_TYPE=    # 0=EOA (key holds funds) | 1=email/Magic | 2=browser wallet
# OPTIONAL: leave blank to use public Polygon RPCs (a fallback list is tried).
POLYGON_RPC_URL=
# OPTIONAL: collateral token for /balance display. CLOB V2 (2026-04-28) moved
# collateral from USDC.e to pUSD; set this to your pUSD contract address (check
# the token under Token Holdings on polygonscan for your funder) so /balance
# matches the site's Cash. Blank = sum USDC.e + native USDC only.
POLYMARKET_COLLATERAL_TOKEN=
